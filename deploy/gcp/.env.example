# Synod – GCP deployment environment variables
# Copy to .env and fill in real values:
#   cp .env.example .env && vi .env
#
# Future: migrate secrets to GCP Secret Manager.

# --- Required ---
GEMINI_API_KEY=gemini-key

# --- Optional (needed for SEC EDGAR data agent) ---
# Note: .env is sourced by bash — values with spaces must be quoted.
SEC_EDGAR_USER_AGENT="Your Agent"
