# Synod – GCP deployment environment variables
# Copy to .env and fill in real values:
#   cp .env.example .env && vi .env
#
# Future: migrate secrets to GCP Secret Manager.

# --- Required ---
GEMINI_API_KEY=your-gemini-api-key

# --- Optional (needed for web-search tool) ---
GOOGLE_CSE_API_KEY=your-google-cse-api-key
GOOGLE_CSE_CX=your-google-cse-cx

# --- Optional (needed for SEC EDGAR data agent) ---
# Note: .env is sourced by bash — values with spaces must be quoted.
SEC_EDGAR_USER_AGENT="YourCompany contact@example.com"
